        "id": "e58ba3fc7f8b84bf",
        "type": "function",
        "z": "6add8d272f432a47",
        "name": "Error Processing",
        "func": "\nif (msg.payload.destination == null || msg.payload.msg == null) {\n    msg.payload = \"Error\";\n    msg.topic = \"parameter\";\n} else {\n    flow.set(\"aasappendresponse\", msg);\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
