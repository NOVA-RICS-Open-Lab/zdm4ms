        "name": "Pre-processing for printer status",
        "func": "\nif (msg.payload.destination == null) {\n    msg.payload = \"Error\";\n    msg.topic = \"parameter\";\n} else {\n    msg.url = \"http://\" + msg.payload.destination + \":80/api/job\";\n    msg.method = \"GET\";\n    msg.headers = {\n    \"Content-Type\": \"application/json\",\n    \"X-Api-Key\": msg.payload.key\n    }\n}\n\nreturn msg;\n\n//\"X-Api-Key\": \"-cqzgIHdAaLvW-9EbK6dXW5019dvLPgNyxP7tEwscFw\"",
