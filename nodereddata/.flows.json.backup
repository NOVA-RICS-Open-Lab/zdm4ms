        "func": "\nif (msg.payload == \"Error\"){\n    msg.statusCode = 400;\n\n    if (msg.topic == \"parameter\") {\n        msg.payload = \"|ERROR|: Parameter error\";\n    } else {\n        msg.payload = \"|ERROR|: Something unexpected happened\";\n    }\n\n    return msg;\n}",
