        "type": "function",
        "z": "6add8d272f432a47",
        "name": "post-processing",
        "func": "let results = msg.payload;\n\nmsg = flow.get(\"aasappendresponse\");\n\nmsg.statusCode = 200;\nmsg.payload = results;\n\nreturn msg;",
