    {
        "id": "122aa7b56918a641",
        "type": "function",
        "z": "6add8d272f432a47",
        "name": "Pre-processing for AAS",
        "func": "const baseUrl = \"http://\" + msg.payload.destination + \"/submodels/aHR0cHM6Ly9leGFtcGxlLmNvbS9pZHMvc20vNjA1MF8zMTMwXzYwNTJfODY2MA/submodel-elements/\";\n\nlet keysData = msg.payload.msg;\n\nconst aasBaseData = {\n    category: \"\",\n    semanticId: {\n        type: \"ModelReference\",\n        keys: [{\n            type: \"ConceptDescription\",\n            value: \"https://example.com/ids/cd/1162_4162_5052_4762\"\n        }]\n    },\n    valueType: \"xs:string\",\n    modelType: \"Property\"\n};\n\nconst keys = {\n    timestamp: \"timestamp\",\n    temp_nozzle: \"nozzle_temp\",\n    temp_target_nozzle: \"nozzle_target\",\n    temp_delta_nozzle: \"nozzle_delta\",\n    pwm_nozzle: \"nozzle_pwm\",\n    temp_bed: \"bed_temp\",\n    temp_target_bed: \"bed_target\",\n    temp_delta_bed: \"bed_delta\",\n    pwm_bed: \"bed_pwm\",\n    \"X\": \"X\",\n    \"Y\": \"Y\",\n    \"Z\": \"Z\",\n    \"E\": \"E\",\n    speed_factor: \"speed_factor\",\n    filename: \"filename\"\n};\n\nconst messages = [];\n\nfor (let key in keys) {\n    const value = keysData[key];\n    if (value !== undefined && value !== null && value !== \"None\") {\n        messages.push({\n            method: \"PUT\",\n            url: baseUrl + keys[key] + \".value\",\n            //payload: { ...aasBaseData, idShort: keys[key], value: String(value) }\n            payload: { ...aasBaseData, idShort: \"value\", value: String(value) }\n        });\n    }\n}\n\n//return [messages];\n\nlet newMsg = {\n    payload: messages\n}\n\nreturn newMsg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1050,
        "y": 3020,
        "wires": [
            [
                "49b0bd781a5da768",
                "c708fbf1263202d2"
            ]
        ]
    },
    {
        "id": "7fd518ac592a03bd",
        "type": "debug",
        "z": "6add8d272f432a47",
        "name": "debug 55",
        "active": false,
        "tosidebar": true,
