    {
        "id": "bef8870c0a47902b",
        "type": "function",
        "z": "6add8d272f432a47",
        "name": "post-processing",
        "func": "let resultsUnformated = msg.payload;\n\nvar resultsFormatedTotal = [];\n\nfor (let product of resultsUnformated) {\n\n    var resultsFormatedProduct = [];\n\n    for (let response of product.submodelElements[4].value){\n        resultsFormatedProduct.push({[response.idShort] : response.value});\n    }\n\n    const id = product.submodelElements[0].value;\n    const type = product.submodelElements[1].value;\n\n    resultsFormatedTotal.push({ [id]: { \"type\": type, \"dimensions\": resultsFormatedProduct }});\n    \n}\n\nmsg.statusCode = 200;\nmsg = flow.get(\"aasgetresponse\");\n\nmsg.payload = resultsFormatedTotal;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 2320,
        "y": 4100,
        "wires": [
