        "type": "function",
        "z": "6add8d272f432a47",
        "name": "post-processing",
        "func": "if (msg.statusCode == 200 || msg.statusCode == 204){\n    return msg;\n} else {\n    msg.payload = \"|Error|: \"+ msg.payload;\n    return msg;\n}",
