        "id": "7e9272c3c0f0aff0",
        "type": "function",
        "z": "6add8d272f432a47",
        "name": "Error",
        "func": "\nif (msg.payload == \"Error\"){\n    msg.statusCode = 400;\n\n    if (msg.topic == \"parameter\") {\n        msg.payload = \"|ERROR|: Parameter error\";\n    } else if (msg.topic == \"destination\") {\n        msg.payload = \"|ERROR|: Destination does not match\";\n    } else if (msg.topic == \"printer\") {\n        msg.payload = \"|ERROR|: No active printer\";\n    } else {\n        msg.payload = \"|ERROR|: Something unexpected happened\";\n    }\n\n    return msg;\n}",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
