    {
        "id": "e5ff5a44369f2393",
        "type": "function",
        "z": "6add8d272f432a47",
        "d": true,
        "name": "post-processing",
        "func": "let resultsUnformated = msg.payload;\n\nvar resultsFormatedTotal = [];\n\nfor (let product of resultsUnformated) {\n\n    var resultsFormatedProduct = [];\n\n    for (let response of product.value){\n        resultsFormatedProduct.push({[response.idShort] : response.value});\n    }\n\n    const regex = /product(\\d+)/;\n    const match1 = product.semanticId.keys[0].value;\n    const id = match1.match(regex)[1];\n\n    resultsFormatedTotal.push({[id]: resultsFormatedProduct});\n\n}\n\nnode.warn(resultsFormatedTotal);\n\nmsg.statusCode = 200;\nmsg = flow.get(\"aasgetresponse\");\n\nnode.warn(resultsFormatedTotal);\n\nmsg.payload = resultsFormatedTotal;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
