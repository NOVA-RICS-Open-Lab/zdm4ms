    {
        "id": "678b558b0dfcc4f2",
        "type": "function",
        "z": "6add8d272f432a47",
        "name": "Connection",
        "func": "\nlet password = msg.payload.session;\n\nmsg.payload = msg.oqueestava;\n\nflow.set(\"activeprinter\", msg.payload.destination);\n\nflow.set(\"message\", { \"auth\": msg.payload.username + \":\" + password });\n\nvar newMsg = {\n    //url: \"ws://127.1.1.1:1880/ws/test\"\n    url: \"ws://\" + msg.payload.destination + \":80/sockjs/websocket\"\n};\n\nreturn newMsg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "// Code added here will be run once\n// whenever the node is started.\n\nlet msg = {};\n\nmsg.close = true;\n\nreturn msg;",
        "finalize": "",
        "libs": [],
        "x": 1670,
        "y": 540,
        "wires": [
            [
                "ac9bc67d32f757c0",
                "636eab1a0a13f9f8"
            ]
        ]
    },
    {
        "id": "8166ecadfc33b39d",
        "type": "function",
        "z": "6add8d272f432a47",
        "name": "buffer",
        "func": "/*\nvar printer = flow.get(\"activeprinter\") || [];\n\nvar printerBuffer = flow.get(printer) || [];\n\n//printerBuffer.push({ts: new Date(), msg: msg.payload});\n\nprinterBuffer.push(msg.payload);\n\nflow.set(printer, printerBuffer);\n*/\n/////////////////////////////////////////////7\n\nvar printer = flow.get(\"activeprinter\") || [];\n\nvar bufferteste = flow.get(\"buffertestee\") || [];\n\nvar printerBuffer = flow.get(printer) || [];\n\nbufferteste.push({ts: new Date(), msg: msg.payload});\n\n//printerBuffer.push(msg.payload);\nprinterBuffer.push({ts: new Date(), msg: msg.payload});\n\nflow.set(printer, printerBuffer);\nflow.set(\"buffertestee\", bufferteste);",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
