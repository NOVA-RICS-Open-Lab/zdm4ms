        "func": "msg.url = \"http://\" + msg.payload.destination + \"/shells\";\nmsg.method = \"POST\";\n\nvar messageTemplate = {\n  \"idShort\": \"Product_\" + msg.payload.id,\n  \"id\": \"http://zdm.com/aas#Product\" + msg.payload.id,\n  \"assetInformation\": {\n    \"assetKind\": \"Instance\",\n    \"globalAssetId\": \"http://zdm.com/assets#Product\" + msg.payload.id,\n    \"assetType\": \"Product \" + msg.payload.id\n  },\n  \"submodels\": [\n    {\n      \"type\": \"ModelReference\",\n      \"keys\": [\n        {\n          \"type\": \"Submodel\",\n          \"value\": \"http://zdm.com/submodels#Product_Stages\"\n        }\n      ]\n    },\n    {\n      \"type\": \"ModelReference\",\n      \"keys\": [\n        {\n          \"type\": \"Submodel\",\n          \"value\": \"http://zdm.com/submodels#Product_Products\"\n        }\n      ]\n    },\n    {\n      \"type\": \"ModelReference\",\n      \"keys\": [\n        {\n          \"type\": \"Submodel\",\n          \"value\": \"http://zdm.com/submodels#Product_Skills\"\n        }\n      ]\n    },\n    {\n      \"type\": \"ModelReference\",\n      \"keys\": [\n        {\n          \"type\": \"Submodel\",\n          \"value\": \"http://zdm.com/submodels#Product_Data\"\n        }\n      ]\n    }\n  ]\n}\n\nvar toma = {\n  \"extensions\": [\n    {\n      \"semanticId\": {\n        \"type\": \"externalReference\",\n        \"referredSemanticId\": \"string\",\n        \"keys\": [\n          {\n            \"type\": \"annotatedRelationshipElement\",\n            \"value\": \"string\"\n          }\n        ]\n      },\n      \"name\": \"string\",\n      \"valueType\": \"anyUri\",\n      \"value\": \"string\",\n      \"refersTo\": [\n        {\n          \"type\": \"externalReference\",\n          \"referredSemanticId\": \"string\",\n          \"keys\": [\n            {\n              \"type\": \"annotatedRelationshipElement\",\n              \"value\": \"string\"\n            }\n          ]\n        }\n      ]\n    }\n  ],\n  \"category\": \"string\",\n  \"idShort\": \"string\",\n  \"displayName\": [\n    {\n      \"language\": \"string\",\n      \"text\": \"string\"\n    }\n  ],\n  \"description\": [\n    {\n      \"language\": \"string\",\n      \"text\": \"string\"\n    }\n  ],\n  \"administration\": {\n    \"embeddedDataSpecifications\": [\n      {\n        \"dataSpecification\": {\n          \"type\": \"externalReference\",\n          \"referredSemanticId\": \"string\",\n          \"keys\": [\n            {\n              \"type\": \"annotatedRelationshipElement\",\n              \"value\": \"string\"\n            }\n          ]\n        },\n        \"dataSpecificationContent\": {}\n      }\n    ],\n    \"version\": \"string\",\n    \"revision\": \"string\",\n    \"creator\": {\n      \"type\": \"externalReference\",\n      \"referredSemanticId\": \"string\",\n      \"keys\": [\n        {\n          \"type\": \"annotatedRelationshipElement\",\n          \"value\": \"string\"\n        }\n      ]\n    },\n    \"templateId\": \"string\"\n  },\n  \"id\": \"string\",\n  \"embeddedDataSpecifications\": [\n    {\n      \"dataSpecification\": {\n        \"type\": \"externalReference\",\n        \"referredSemanticId\": \"string\",\n        \"keys\": [\n          {\n            \"type\": \"annotatedRelationshipElement\",\n            \"value\": \"string\"\n          }\n        ]\n      },\n      \"dataSpecificationContent\": {}\n    }\n  ],\n  \"derivedFrom\": {\n    \"type\": \"externalReference\",\n    \"referredSemanticId\": \"string\",\n    \"keys\": [\n      {\n        \"type\": \"annotatedRelationshipElement\",\n        \"value\": \"string\"\n      }\n    ]\n  },\n  \"assetInformation\": {\n    \"assetKind\": \"type\",\n    \"globalAssetId\": \"string\",\n    \"specificAssetIds\": [\n      {\n        \"semanticId\": {\n          \"type\": \"externalReference\",\n          \"referredSemanticId\": \"string\",\n          \"keys\": [\n            {\n              \"type\": \"annotatedRelationshipElement\",\n              \"value\": \"string\"\n            }\n          ]\n        },\n        \"supplementalSemanticIds\": [\n          {\n            \"type\": \"externalReference\",\n            \"referredSemanticId\": \"string\",\n            \"keys\": [\n              {\n                \"type\": \"annotatedRelationshipElement\",\n                \"value\": \"string\"\n              }\n            ]\n          }\n        ],\n        \"name\": \"string\",\n        \"value\": \"string\",\n        \"externalSubjectId\": {\n          \"type\": \"externalReference\",\n          \"referredSemanticId\": \"string\",\n          \"keys\": [\n            {\n              \"type\": \"annotatedRelationshipElement\",\n              \"value\": \"string\"\n            }\n          ]\n        }\n      }\n    ],\n    \"assetType\": \"string\",\n    \"defaultThumbnail\": {\n      \"path\": \"string\",\n      \"contentType\": \"string\"\n    }\n  },\n  \"submodels\": [\n    {\n      \"type\": \"externalReference\",\n      \"referredSemanticId\": \"string\",\n      \"keys\": [\n        {\n          \"type\": \"annotatedRelationshipElement\",\n          \"value\": \"string\"\n        }\n      ]\n    }\n  ],\n  \"parent\": {},\n  \"timeStampCreate\": \"2025-07-28T14:11:38.347Z\",\n  \"timeStamp\": \"2025-07-28T14:11:38.347Z\",\n  \"timeStampTree\": \"2025-07-28T14:11:38.347Z\",\n  \"timeStampDelete\": \"2025-07-28T14:11:38.347Z\",\n  \"diaryData\": {}\n}\n\nmsg.payload = messageTemplate;\n\nreturn msg;",
