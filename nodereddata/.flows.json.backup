    {
        "id": "027b7382a9695526",
        "type": "function",
        "z": "6add8d272f432a47",
        "name": "Pre-processing for printer subscription",
        "func": "let activeprinter = flow.get(\"activeprinter\") || \"\";\n\nif (msg.payload.destination == null){\n    msg.payload = \"Error\";\n    msg.topic = \"parameter\";\n} else if (activeprinter == \"\") {\n    msg.payload = \"Error\";\n    msg.topic = \"printer\";\n} else if (activeprinter != msg.payload.destination) {\n    msg.payload = \"Error\";\n    msg.topic = \"destination\";\n}\n\nflow.set(\"activeprinter\", \"\");\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "// Code added here will be run once\n// whenever the node is started.\n\nflow.set(\"activeprinter\", \"\");",
        "finalize": "",
        "libs": [],
