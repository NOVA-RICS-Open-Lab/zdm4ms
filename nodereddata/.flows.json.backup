        "id": "8ecfdedebaca31ad",
        "type": "function",
        "z": "6add8d272f432a47",
        "name": "Pre-processing for prediction",
        "func": "\nif (msg.payload.destination == null || msg.payload.msg == null) {\n    msg.payload = \"Error\";\n    msg.topic = \"parameter\";\n} else {\n    msg.url = \"http://\" + msg.payload.destination + \"/predict1\";\n    msg.method = \"POST\";\n    msg.payload = msg.payload.msg;\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
