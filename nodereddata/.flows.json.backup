    {
        "id": "edbf74d9d04d7d08",
        "type": "function",
        "z": "6add8d272f432a47",
        "name": "Pre-processing for AAS",
        "func": "const shell = Buffer.from(\"http://zdm.com/aas#Product\" + msg.payload.shellid, 'utf8').toString('base64url');\n\nconst submodel = Buffer.from(\"http://zdm.com/submodels#Product_Data_\" + msg.payload.shellid, 'utf8').toString('base64url');\n\nconst submodelElement = \"dimensions.\" + msg.payload.dimension;\n\nmsg.url = \"http://\" + msg.payload.destination + \"/shells/\" + shell + \"/submodels/\" + submodel + \"/submodel-elements/\" + submodelElement;\nmsg.method = \"PATCH\";\n\nconst aasBaseData = {\n    category: \"\",\n    semanticId: {\n        type: \"ModelReference\",\n        keys: [{\n            type: \"ConceptDescription\",\n            value: \"http://zdm.com/product\" + msg.payload.shellid + \"#\" + msg.payload.dimension\n        }]\n    },\n    valueType: \"xs:string\",\n    modelType: \"Property\"\n};\n\nmsg.payload = { ...aasBaseData, idShort: msg.payload.dimension, value: String(msg.payload.value) }\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1170,
        "y": 3260,
