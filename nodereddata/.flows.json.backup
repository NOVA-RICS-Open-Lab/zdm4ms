        "id": "03013a4bd09152df",
        "type": "function",
        "z": "6add8d272f432a47",
        "name": "Pre-processing for AAS",
        "func": "const messages = [];\n\nfor (let id of msg.payload.msg) {\n\n    const shell = Buffer.from(\"http://zdm.com/aas#Product\" + id, 'utf8').toString('base64url');\n    //const shell = \"http://zdm.com/aas#Product\" + id;\n    const submodel = Buffer.from(\"http://zdm.com/submodels#Product_Data_\" + id, 'utf8').toString('base64url');\n\n    //let urlFinal = \"http://\" + msg.payload.destination + \"/shells/\" + shell + \"/submodels/\" + submodel + \"/submodel-elements/dimensions\";\n    let urlFinal = \"http://\" + msg.payload.destination + \"/shells/\" + shell + \"/submodels/\" + submodel;\n\n    messages.push({\n        method: \"GET\",\n        url: urlFinal,\n    });\n}\n\nlet newMsg = {\n    payload: messages\n}\n\nreturn newMsg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
