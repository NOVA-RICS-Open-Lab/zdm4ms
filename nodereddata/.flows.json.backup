    {
        "id": "47fea1cce2134bf5",
        "type": "function",
        "z": "6add8d272f432a47",
        "name": "AAS Creator",
        "func": "\nvar id = msg.payload.id;\n\nvar type = msg.payload.type; // TUDO EM GRANDE \"E ESTES?\" \n\nvar templateQuadradoRetangulo = {\n  \"assetAdministrationShells\": [\n    {\n      \"idShort\": \"Product_\" + id,\n      \"id\": \"http://zdm.com/aas#Product\" + id,\n      \"assetInformation\": {\n        \"assetKind\": \"Instance\",\n        \"globalAssetId\": \"http://zdm.com/assets#Product\" + id,\n        \"assetType\": \"Product \" + id\n      },\n      \"submodels\": [\n        {\n          \"type\": \"ModelReference\",\n          \"keys\": [\n            {\n              \"type\": \"Submodel\",\n              \"value\": \"http://zdm.com/submodels#Product_Stages_\" + id\n            }\n          ]\n        },\n        {\n          \"type\": \"ModelReference\",\n          \"keys\": [\n            {\n              \"type\": \"Submodel\",\n              \"value\": \"http://zdm.com/submodels#Product_Products_\" + id\n            }\n          ]\n        },\n        {\n          \"type\": \"ModelReference\",\n          \"keys\": [\n            {\n              \"type\": \"Submodel\",\n              \"value\": \"http://zdm.com/submodels#Product_Skills_\" + id\n            }\n          ]\n        },\n        {\n          \"type\": \"ModelReference\",\n          \"keys\": [\n            {\n              \"type\": \"Submodel\",\n              \"value\": \"http://zdm.com/submodels#Product_Data_\" + id\n            }\n          ]\n        }\n      ],\n      \"modelType\": \"AssetAdministrationShell\"\n    }\n  ],\n  \"submodels\": [\n    {\n      \"idShort\": \"Product_Stages\",\n      \"id\": \"http://zdm.com/submodels#Product_Stages_\" + id,\n      \"kind\": \"Instance\",\n      \"semanticId\": {\n        \"type\": \"ModelReference\",\n        \"keys\": [\n          {\n            \"type\": \"Submodel\",\n            \"value\": \"http://zdm.com/submodels#Product_Stages_\" + id\n          }\n        ]\n      },\n      \"submodelElements\": [\n        {\n     