    {
        "id": "16f8f1a8e5f37f0c",
        "type": "function",
        "z": "6add8d272f432a47",
        "name": "Pre-processing for printer command",
        "func": "\nif (msg.payload.msg == null || msg.payload.destination == null || msg.payload.destination == null) {\n    msg.payload = \"Error\";\n    msg.topic = \"parameter\";\n} else {\n    msg.url = \"http://\" + msg.payload.destination + \":80/api/printer/command\";\n    msg.method = \"POST\";\n    msg.headers = {\n    \"Content-Type\": \"application/json\",\n    \"X-Api-Key\": msg.payload.key\n    }\n    msg.payload = {\n        command: msg.payload.msg\n    }\n}\n\nreturn msg;\n\n\n//\"X-Api-Key\": \"-cqzgIHdAaLvW-9EbK6dXW5019dvLPgNyxP7tEwscFw\"",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 620,
        "y": 180,
        "wires": [
            [
                "ccca9d9911eff2fd",
                "0e44d63ba0c3cb35",
                "ebbdee6d4471ebb0"
            ]
        ]
    },
    {
        "id": "1951c875d5ea2c9c",
        "type": "function",
        "z": "6add8d272f432a47",
        "name": "post-processing",
        "func": "if (msg.statusCode == 200 || msg.statusCode == 204){\n    return msg;\n} else {\n    msg.payload = \"|Error|: \"+ msg.payload;\n    return msg;\n}",
        "outputs": 1,
