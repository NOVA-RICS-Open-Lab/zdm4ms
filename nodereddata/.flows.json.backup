    {
        "id": "48a5760eb4dd5dc3",
        "type": "function",
        "z": "6add8d272f432a47",
        "name": "Pre-processing for AAS",
        "func": "const shell = Buffer.from(\"http://zdm.com/aas#Product\" + msg.payload.shellid, 'utf8').toString('base64url');\n\nconst submodel = Buffer.from(\"http://zdm.com/submodels#Product_Data_\" + msg.payload.shellid, 'utf8').toString('base64url');\n\nconst messages = [];\n\nfor (const [key, value] of Object.entries(msg.payload.msg)) {\n    if (value !== undefined && value !== null && value !== \"None\") {\n        \n        const aasBaseData = {\n            category: \"\",\n            semanticId: {\n                type: \"ModelReference\",\n                keys: [{\n                    type: \"ConceptDescription\",\n                    value: \"http://zdm.com/product\" + msg.payload.shellid + \"#\" + key\n                }]\n            },\n            valueType: \"xs:string\",\n            modelType: \"Property\"\n        };\n        \n        const submodelElement = \"dimensions.\" + key;\n\n        let urlFinal = \"http://\" + msg.payload.destination + \"/shells/\" + shell + \"/submodels/\" + submodel + \"/submodel-elements/\" + submodelElement;\n\n        messages.push({\n            method: \"PATCH\",\n            url: urlFinal,\n            payload : { ...aasBaseData, idShort: msg.payload.dimension, value: String(value) }\n        });\n    }\n}\n\nlet newMsg = {\n    payload: messages\n}\n\nreturn newMsg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1110,
        "y": 3560,
        "wires": [
            [
                "107e2ed2f1655c85",
                "e261979b6c307209"
            ]
        ]
    },
